{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "emulators": {
    "firestore": {
      "port": 4002 
    },
    "ui": {
      "enabled": true,
      "port": 4003  
    },
    "functions": {
      "port": 5002  
    },
    "database": {
      "port": 9001  
    },
    "hosting": {
      "port": 5003 
    },
    "storage": {
      "port": 9200  
    }
  },
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint"
    ]
  }
}